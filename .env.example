# App
APP_ENV=development
DEBUG=true

# Firebase (use one of the two options below)
FIREBASE_CREDENTIALS_PATH=firebase-credentials.json   # local dev
FIREBASE_CREDENTIALS_JSON=                            # production (Fly.io secret — full JSON string)

# Anthropic
ANTHROPIC_API_KEY=sk-ant-...

# CORS — comma-separated list of allowed frontend origins
ALLOWED_ORIGINS=["http://localhost:3000","http://localhost:5173","https://your-frontend.vercel.app"]

# Super Admin
SUPER_ADMIN_EMAIL=your@email.com

# Token budgets
DAILY_TOKEN_BUDGET=50000          # per-user daily limit (tokens)
ORG_DAILY_TOKEN_BUDGET=2000000    # org-wide daily limit (tokens)

# Sentry (optional — leave blank to disable)
SENTRY_DSN=
